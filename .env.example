# ── InkScope 环境变量 ──
# 复制本文件为 .env，填入你要用的服务商 Key
# 至少配置一个服务商即可运行

# 豆包 (Doubao / 字节跳动)
DOUBAO_API_KEY=sk-your-doubao-key-here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_CHAT_MODEL=doubao-pro-32k
# DOUBAO_OCR_MODEL=doubao-pro-32k

# DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-v4-pro

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 指定默认服务商（不设置则自动使用第一个有 Key 的）
# DEFAULT_TEXT_PROVIDER=doubao
# DEFAULT_OCR_PROVIDER=doubao

# 服务端口（默认 8078）
# PORT=8078
